# Backend environment variables
# Copy this file to .env and fill in your values

# MongoDB connection string
# For local dev: mongodb://127.0.0.1:27017/mini_enterprise_portal
# For Docker Compose: mongodb://mongodb:27017/mini_enterprise_portal
# For Kubernetes: mongodb://mongodb:27017/mini_enterprise_portal
MONGODB_URI=mongodb://127.0.0.1:27017/mini_enterprise_portal

# JWT secret — use a long random string in production
JWT_SECRET=your-super-secret-jwt-key

# Company email domain for registration validation
COMPANY_EMAIL_DOMAIN=company.com

# OpenAI API key (get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Server port (default: 5000)
PORT=5000

# Frontend — Vite build-time variable (set during docker build)
# VITE_API_URL=http://<azure-vm-ip>:30500
